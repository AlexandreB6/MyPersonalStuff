// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Peinture possédée par l'utilisateur (multi-gamme)
model OwnedPaint {
  id        Int      @id @default(autoincrement())
  paintId   String   /// Identifiant slug de la peinture (ex: "abaddon-black")
  range     String   @default("citadel") /// Gamme de peinture ("citadel", "monument-hobbies")
  quantity  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([paintId, range])
}

/// Manga suivi dans la collection personnelle
model Manga {
  id             Int      @id @default(autoincrement())
  malId          Int      @unique /// Identifiant MyAnimeList
  title          String
  titleJapanese  String?
  coverImage          String?  /// URL image couverture (MAL/Jikan)
  editionCoverImage   String?  /// URL image couverture choisie par l'utilisateur
  author         String?
  volumes        Int?     /// Nb volumes total (null si en cours)
  chapters       Int?     /// Nb chapitres total
  synopsis       String?
  genres         String?  /// Genres séparés par virgule
  demographic    String?  /// Démographie : "Shounen", "Seinen", "Shoujo", "Josei"
  score          Float?   /// Score MAL
  status         String?  /// "Publishing", "Finished", etc.
  ownedVolumesMap String  @default("[]") /// JSON array des numéros de volumes possédés, ex: "[1,2,3,5]"
  notes          String?  /// Notes perso
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Film suivi dans la collection personnelle
model Movie {
  id          Int       @id @default(autoincrement())
  tmdbId      Int?      @unique /// Identifiant TMDB pour enrichir les métadonnées
  title       String
  posterPath  String?
  overview    String?
  director    String?
  releaseYear Int?
  watchedAt   DateTime /// Date à laquelle le film a été vu
  rating      Int?     /// Note personnelle (1-5)
  owned       Boolean   @default(false) /// Possède un exemplaire physique
  ownedFormat String?  /// Format possédé (DVD, Blu-ray, etc.)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
