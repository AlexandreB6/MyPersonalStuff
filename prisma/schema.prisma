// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Peinture possédée par l'utilisateur (multi-gamme)
model OwnedPaint {
  id        Int      @id @default(autoincrement())
  paintId   String   /// Identifiant slug de la peinture (ex: "abaddon-black")
  range     String   @default("citadel") /// Gamme de peinture ("citadel", "monument-hobbies")
  quantity  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([paintId, range])
}

/// Manga suivi dans la collection personnelle (source: Google Books FR + BnF SRU)
model Manga {
  id              Int      @id @default(autoincrement())
  googleBooksId   String?  @unique /// ID Google Books de la série (optionnel, pour preview avant ajout)
  title           String   /// Titre de la série
  titleJapanese   String?
  coverImage      String?  /// URL image couverture
  author          String?
  publisher       String?  /// Éditeur FR (Glénat, Kana, Pika, Panini, Planète BD…)
  editionLabel    String?  /// Édition (Standard, Deluxe, Intégrale, Perfect Edition…)
  volumes         Int?     /// Nb volumes total de cette édition FR (null si en cours)
  synopsis        String?
  genres          String?  /// Genres séparés par virgule
  demographic     String?  /// Démographie : "Shounen", "Seinen", "Shoujo", "Josei"
  status          String?  /// "Publishing", "Finished", etc.
  source          String   @default("google-books") /// "google-books" | "bnf"
  ownedVolumesMap String   @default("[]") /// JSON array des numéros de volumes possédés, ex: "[1,2,3,5]"
  notes           String?  /// Notes perso
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([title, publisher, editionLabel])
}

/// Film suivi dans la collection personnelle
model Movie {
  id          Int       @id @default(autoincrement())
  tmdbId      Int?      @unique /// Identifiant TMDB pour enrichir les métadonnées
  title       String
  posterPath  String?
  overview    String?
  director    String?
  releaseYear Int?
  watchedAt        DateTime? /// Date à laquelle le film a été vu (optionnelle)
  watchedPrecision String    @default("day") /// Précision de la date : "day" ou "year"
  rating      Float?    /// Note personnelle (0.5–5, par pas de 0.5)
  owned       Boolean   @default(false) /// Possède un exemplaire physique
  ownedFormat String?  /// Format possédé (DVD, Blu-ray, etc.)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
